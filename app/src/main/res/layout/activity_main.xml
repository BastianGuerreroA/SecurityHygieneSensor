<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:id="@+id/main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECURITY SENSOR"
            android:textColor="@color/ring_light_blue"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"/>

        <!-- Anillo + Score -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp">

            <ProgressBar
                android:id="@+id/circularProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/ring_progress"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivShield"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_shield_heart"
                    android:contentDescription="@string/shield_heart_desc"/>

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/ring_light_blue"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 100 pts"
                    android:textColor="@color/ring_dark"
                    android:textSize="11sp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Badge de estado -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRESIONA ESCANEAR"
            android:textColor="@color/ring_dark"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="@drawable/badge_background"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Tarjeta PIN -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dotPin"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_shape"
                    android:backgroundTint="@color/ring_dark"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bloqueo de pantalla"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvPinVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin escanear"
                        android:textColor="@color/ring_dark"
                        android:textSize="11sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvPinPts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0"
                    android:textColor="@color/ring_dark"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Biometría -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dotBio"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_shape"
                    android:backgroundTint="@color/ring_dark"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Biometría"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvBioVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin escanear"
                        android:textColor="@color/ring_dark"
                        android:textSize="11sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvBioPts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0"
                    android:textColor="@color/ring_dark"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Parche -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dotPatch"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_shape"
                    android:backgroundTint="@color/ring_dark"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parche de seguridad"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvPatchVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin escanear"
                        android:textColor="@color/ring_dark"
                        android:textSize="11sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvPatchPts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0"
                    android:textColor="@color/ring_dark"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Apps Desconocidas -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/dotApps"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_shape"
                    android:backgroundTint="@color/ring_dark"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apps desconocidas"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvAppsVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin escanear"
                        android:textColor="@color/ring_dark"
                        android:textSize="11sp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvAppsPts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0"
                    android:textColor="@color/ring_dark"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón -->
        <Button
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ESCANEAR AHORA"
            android:textColor="@color/bg_dark"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:backgroundTint="@color/ring_light_blue"/>

    </LinearLayout>
</ScrollView>